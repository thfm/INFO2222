# Required: server-side pepper used as HMAC key before Argon2 hashing.
# Must be >= 16 chars. Rotate only in coordination with password re-hashing.
PEPPER=change-me-to-a-long-random-string-at-least-32-bytes

# Set to 1 for the Task 2 weak-hashing vulnerability demo (MD5, no salt).
# Leave 0 for Task 1.1 strong-hashing submission.
WEAK_MODE=0

# HTTP port for the local dev server.
PORT=3000
